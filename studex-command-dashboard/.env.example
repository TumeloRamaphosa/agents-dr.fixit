# Default model tag shown in the assistant (override in UI anytime)
VITE_OLLAMA_MODEL=llama3.2:latest

# Optional: when not using `npm run dev` proxy, set full origin and allow CORS on Ollama (OLLAMA_ORIGINS)
# VITE_OLLAMA_BASE_URL=http://127.0.0.1:11434

# Optional: Fly Machines API — dev/preview only (injected by Vite proxy, never ship to public static hosting)
# Create token: https://fly.io/docs/security/tokens/
VITE_FLY_API_TOKEN=

# Optional production Fly proxy base (if you run your own backend/reverse proxy)
# VITE_FLY_API_BASE_URL=https://your-proxy.example/fly
