# Dr.Fixit Agent System - Git Ignore

# Logs (keep directory, ignore contents)
logs/*.log
logs/*.txt
!logs/.gitkeep
*.log

# PID files
*.pid
/tmp/*.pid

# Runtime data
.memory/
backups/
status/
valley/data/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Environment
.env
.env.local
*.key
*.pem

# Models (large files, download separately)
models/
*.safetensors
*.gguf
*.bin
*.tar.gz
*.zip
*.dmg

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Temporary files
*.tmp
*.temp
.cache/

# Build artifacts
dist/
build/
